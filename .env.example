# OpenRouter API — powers Nemotron 70B
OPENROUTER_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Optional: set to "true" to use mock agent responses instead of calling OpenRouter (useful for UI dev)
MOCK_AGENTS=false
