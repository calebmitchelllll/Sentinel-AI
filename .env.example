# ── Inference ────────────────────────────────────────────────────────────────
# On NVIDIA Brev: set BREV_NIM_URL to the local NIM endpoint (e.g. http://localhost:8000)
# and leave OPENROUTER_API_KEY blank — the app will use the local GPU instead.
# In local dev (no Brev): leave BREV_NIM_URL blank and set OPENROUTER_API_KEY.
BREV_NIM_URL=
OPENROUTER_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ── Dev helpers ───────────────────────────────────────────────────────────────
# Set to "true" to skip all model calls and return instant mock responses (UI dev only)
MOCK_AGENTS=false
