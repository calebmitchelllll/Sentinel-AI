# Copy this file to .env and fill in real values.

# --- NVIDIA / NemoClaw -------------------------------------------------------
# Get one from build.nvidia.com or your NemoClaw setup. Both env var names work.
NVIDIA_API_KEY=nvapi-...
NEMOCLAW_API_KEY=nvapi-...

# Optional overrides
NEMOTRON_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Supabase ----------------------------------------------------------------
# From Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...           # safe to expose
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...               # SECRET — server only

# --- Next.js / app -----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_SECRET=                                  # any long random string

# --- Wiring ------------------------------------------------------------------
# Where the Next.js API routes find the Python orchestrator
NEMOCLAW_SERVICE_URL=http://localhost:8000

# --- AWS (CloudTrail integration) --------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Brev / local NIM ---------------------------------------------------------
# On Brev: set to local NIM endpoint so agents skip OpenRouter and hit the GPU
BREV_NIM_URL=

# --- Dev helpers -------------------------------------------------------------
# "true" = skip all model calls, return instant mock responses
MOCK_AGENTS=false
