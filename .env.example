# AWS credentials (for CloudTrail log ingestion)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# NVIDIA NIM API (powers all agents)
NVIDIA_API_KEY=nvapi-your-key-here
NEMOCLAW_API_KEY=nvapi-your-key-here
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Set to "true" to skip NIM calls and return instant mock responses (UI testing)
MOCK_AGENTS=false

# Optional: local NIM service
NEMOCLAW_SERVICE_URL=http://localhost:8000
